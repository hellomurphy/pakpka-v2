# Local dev: use same SQLite as Wrangler D1 so nuxt dev and Drizzle Studio see the same data.
# You can use a relative path (e.g. file:../../.wrangler/...); the app resolves it to an absolute path from apps/admin.
# Run D1 migration at least once from repo root: pnpm --filter @repo/db run db:migrate:local (or wrangler d1 execute pakpak-db --local --file=...)
# If the hash changes: ls .wrangler/state/v3/d1/miniflare-D1DatabaseObject/
# DATABASE_URL=file:../../.wrangler/state/v3/d1/miniflare-D1DatabaseObject/2745d5729486eded0d5c46a716e77d229e8e2423b6797adb34288688958525b6.sqlite

# Dev login (optional): user id to use when visiting /api/auth/dev-login in dev
# DEV_USER_ID=

# CORS: comma-separated origins allowed to call admin API (e.g. client, landing)
# Dev: http://localhost:3002   Prod: https://your-client-domain.com
# ALLOWED_ORIGINS=http://localhost:3002,https://app.example.com

# LINE Login (OAuth2) — ใช้เมื่อไม่ใช้ dev-login
# LINE_CHANNEL_ID=
# LINE_CHANNEL_SECRET=
# LINE_CALLBACK_URL=https://your-admin-domain.com/api/auth/line/callback

# NuxtHub / Cloudflare D1 (production)
# ใช้เมื่อตั้ง hub.db เป็น driver: 'd1-http'
# NUXT_HUB_CLOUDFLARE_ACCOUNT_ID=
# NUXT_HUB_CLOUDFLARE_API_TOKEN=
# NUXT_HUB_CLOUDFLARE_DATABASE_ID=
