{
  "name": "pakpak-v2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:quick": "turbo run test:quick --filter=admin",
    "test:full": "turbo run test:full --filter=admin",
    "// --filter=admin": "Only run tests for admin; client and landing test setup are not ready yet.",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.7.4",
    "turbo": "^2.8.9",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
